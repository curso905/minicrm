PORT=4000
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/minicrm?retryWrites=true&w=majority
OPENAI_API_KEY=

# Resend + Nodemailer (SMTP). Crea API key en resend.com y verifica el dominio.
RESEND_API_KEY=
# Remitente verificado, ej: "MiniCRM <onboarding@tudominio.com>"
MAIL_FROM=

# Stripe (Dashboard → Developers → API keys). Test: sk_test_... / pk_test_...
STRIPE_SECRET_KEY=
# Price ID del plan Básico (Product catalog → Basico → price_...). Usado por el botón Membresía.
STRIPE_PRICE_BASICO=
# Opcional: webhook signing secret (Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=
